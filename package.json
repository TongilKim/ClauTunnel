{
  "name": "clautunnel-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Remote monitoring and control for Claude Code CLI",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "cli": "pnpm --filter @tongil_kim/clautunnel",
    "mobile": "pnpm --filter @clautunnel/mobile",
    "shared": "pnpm --filter clautunnel-shared"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
